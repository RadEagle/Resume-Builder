server {
    listen       80;
    listen       [::]:80;
    server_name  {{ nginx_server_names }};

    # Load configuration files for the default server block.
    include /etc/nginx/default.d/*.conf;

    error_page 404 /404.html;
    location = /404.html {
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
    }

    {% if enable_https | bool %}
    location / {
        return 301 https://$host$request_uri;
    }
    {% else %}
    # Route 1: Send API calls to your Python backend
    location /api {
        proxy_pass http://{{ uvicorn_host }}:{{ uvicorn_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Route 2: Send normal visitors to your Frontend
    location / {
        root {{ nginx_frontend_root }};
        index index.html;

        # Keeps React/Vite routing working
        try_files $uri $uri/ /index.html;
    }
    {% endif %}
}
